EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_ENABLE_MOCK_AUTH=true
EXPO_PUBLIC_REQUIRE_REAL_BACKEND=false
EXPO_PUBLIC_API_URL=https://api.axtaris.az

# Local/server-only verification. Never expose this in a client build.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional direct Postgres connection string for psql/Supabase CLI workflows.
# Do not commit real credentials.
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres
